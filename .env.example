GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Opsional: provider utama global. Nilai yang didukung: gemini, groq, 9router.
AI_PROVIDER=gemini
AI_FALLBACK_PROVIDER=groq

# Opsional: routing hemat per tugas. Set fallback per task ke "none" untuk mematikan fallback.
AI_CHAT_PROVIDER=gemini
GEMINI_CHAT_MODEL=gemini-2.5-flash
GROQ_CHAT_MODEL=llama-3.1-8b-instant
AI_EXTRACT_PROVIDER=gemini
GEMINI_EXTRACT_MODEL=gemini-2.5-flash
GROQ_EXTRACT_MODEL=qwen/qwen3-32b
AI_GENERATE_PROVIDER=gemini
AI_GENERATE_FALLBACK_PROVIDER=none
GEMINI_GENERATE_MODEL=gemini-2.5-flash
AI_REVISE_SECTION_PROVIDER=gemini
GEMINI_REVISE_SECTION_MODEL=gemini-2.5-flash
GROQ_REVISE_SECTION_MODEL=qwen/qwen3-32b
AI_REVISE_DOCUMENT_PROVIDER=gemini
AI_REVISE_DOCUMENT_FALLBACK_PROVIDER=none
GEMINI_REVISE_DOCUMENT_MODEL=gemini-2.5-flash

# Opsional: budget guard server-side
AI_DAILY_CHAT_LIMIT=60
AI_DAILY_REVISE_SECTION_LIMIT=20
AI_DAILY_REVISE_DOCUMENT_LIMIT=3
AI_CHAT_HISTORY_LIMIT=12
AI_DEDUPE_TTL_MS=600000

# Opsional: 9Router local gateway (OpenAI-compatible)
# Jalankan 9Router, buka http://localhost:20128, lalu salin API key dari dashboard.
NINE_ROUTER_API_KEY=your_9router_api_key_here
NINE_ROUTER_BASE_URL=http://localhost:20128/v1
NINE_ROUTER_CHAT_MODEL=auto
NINE_ROUTER_GENERATE_MODEL=kr/claude-sonnet-4.5
NINE_ROUTER_REVISE_MODEL=kr/claude-sonnet-4.5

# Opsional: override model untuk proses generate PRD/UI
GROQ_GENERATE_MODEL=llama-3.3-70b-versatile
GENERATE_JSON_MAX_TOKENS=8192
GENERATE_TEXT_MAX_TOKENS=20000
REVISE_TEXT_MAX_TOKENS=20000
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id_here

# Untuk server-side Firebase Admin SDK
FIREBASE_ADMIN_CLIENT_EMAIL=your_firebase_admin_client_email
FIREBASE_ADMIN_PRIVATE_KEY=your_firebase_admin_private_key

# Khusus local/e2e test. Jangan aktifkan di production.
E2E_TEST_AUTH_ENABLED=false
NEXT_PUBLIC_E2E_TEST_AUTH_ENABLED=false
E2E_TEST_UID=testsprite-local-user
E2E_TEST_EMAIL=testsprite@jadiprd.local
E2E_TEST_NAME=TestSprite User
